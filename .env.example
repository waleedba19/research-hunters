# ============================================================
#  Research Hunter - Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# ============================================================
#  PROXY SETTINGS (Optional)
# ============================================================

# Custom proxy URL (format: http://user:pass@host:port)
# Leave empty to disable proxy
PROXY_URL=

# G4F Proxy (auto-detected if using qoder)
G4F_PROXY=

# ============================================================
#  SCI-HUB SETTINGS (Optional)
# ============================================================

# Enable Sci-Hub for PDF downloads (1=enabled, 0=disabled)
SCIHUB_ENABLED=0

# ============================================================
#  RUN SETTINGS
# ============================================================

# Maximum batches per run (each batch = ~50 papers)
# 0 = unlimited (run until complete)
MAX_BATCHES=12

# Default search mode: sample, quick, field, deep
DEFAULT_MODE=deep

# Default language: 1=EN, 2=AR, 3=FR, 4=ES, etc.
DEFAULT_LANGUAGE=1

# ============================================================
#  DOWNLOAD SETTINGS
# ============================================================

# Maximum concurrent downloads
MAX_DOWNLOAD_THREADS=5

# Request timeout in seconds
REQUEST_TIMEOUT=30

# Maximum PDF size in MB
MAX_PDF_SIZE_MB=50

# ============================================================
#  CACHE SETTINGS
# ============================================================

# Checkpoint save interval (papers)
CHECKPOINT_INTERVAL=5

# Cache retention days
CACHE_RETENTION_DAYS=90

# ============================================================
#  OUTPUT SETTINGS
# ============================================================

# Output base directory
OUTPUT_DIR=pdf_files

# Enable single folder mode (true/false)
SINGLE_FOLDER_MODE=false

# ============================================================
#  LOGGING SETTINGS
# ============================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (leave empty for no file logging)
LOG_FILE=

# ============================================================
#  GITHUB ACTIONS SETTINGS
# ============================================================

# GitHub token (auto-set in Actions)
GITHUB_TOKEN=

# Artifacts retention days
ARTIFACTS_RETENTION_DAYS=90

# ============================================================
#  PLATFORM API KEYS (Optional - for enhanced access)
# ============================================================

# Semantic Scholar API key
SEMANTIC_SCHOLAR_API_KEY=

# CrossRef API (no key needed)

# OpenAlex token
OPENALEX_TOKEN=

# ============================================================
#  DEVELOPMENT SETTINGS
# ============================================================

# Enable debug mode (true/false)
DEBUG_MODE=false

# Enable test mode (skips actual downloads)
TEST_MODE=false