# ============================================================
#  .gitignore for Research Hunter v2-4
# ============================================================

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Local caches and runtime data
search_cache.json
search_cache.json.tmp
scopus_cache.json
ghost_credentials.json
search_cache.json.corrupt.json

# Downloaded papers (regenerated by the script)
pdf_files/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log

# Virtual environments
venv/
.venv/
env/

# Test outputs
test_*.py
__pycache__/

# SQL Server Compact database files
*.sdf
